# ============================================
# GOCus ERP/POS — Variables de Entorno (Template)
# ============================================
# Copia este archivo como .env y ajusta los valores

# Database
POSTGRES_USER=gocus
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=gocus_db
DATABASE_URL=postgresql://gocus:CHANGE_THIS_PASSWORD@postgres:5432/gocus_db

# JWT
JWT_SECRET=CHANGE_THIS_SECRET
JWT_REFRESH_SECRET=CHANGE_THIS_REFRESH_SECRET
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# App
BACKEND_PORT=3000
FRONTEND_PORT=5173
NODE_ENV=development
