// ============================================
// GOCus ERP/POS — Prisma Schema
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────
// Organización: Empresa → Sucursal → Almacén
// ──────────────────────────────────────────

model Company {
  id            String   @id @default(uuid())
  name          String   @unique
  tradeName     String?  @map("trade_name")
  taxId         String?  @unique @map("tax_id")
  ubigeo        String?
  sunatProvider String?  @map("sunat_provider")
  apiToken      String?  @map("api_token")
  email         String?
  phone         String?
  address       String?
  logo          String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  branches Branch[]
  users    User[]

  @@map("companies")
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  code      String?
  address   String?
  phone     String?
  email     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  warehouses    Warehouse[]
  users         User[]
  products      Product[]
  customers     Customer[]
  suppliers     Supplier[]
  sales         Sale[]
  purchases     Purchase[]
  inventories   Inventory[]
  kardexEntries KardexEntry[]
  cashRegisters CashRegister[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("branches")
}

model Warehouse {
  id        String   @id @default(uuid())
  name      String
  code      String?
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  inventories   Inventory[]
  kardexEntries KardexEntry[]

  @@unique([branchId, name])
  @@index([branchId])
  @@map("warehouses")
}

// ──────────────────────────────────────────
// Seguridad: Usuarios, Roles, Permisos
// ──────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  phone        String?
  avatar       String?
  isActive     Boolean   @default(true) @map("is_active")
  refreshToken String?   @map("refresh_token")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id])

  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])

  branchId String? @map("branch_id")
  branch   Branch? @relation(fields: [branchId], references: [id])

  auditLogs AuditLog[]
  sales     Sale[]

  @@index([companyId])
  @@index([branchId])
  @@index([roleId])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  module      String
  action      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@unique([module, action])
  @@index([module])
  @@map("permissions")
}

model RolePermission {
  id String @id @default(uuid())

  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id        String   @id @default(uuid())
  entity    String
  entityId  String   @map("entity_id")
  action    String
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ──────────────────────────────────────────
// Catálogo: Productos, Categorías, Marcas, Unidades
// ──────────────────────────────────────────

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  icon        String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parentId String?    @map("parent_id")
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  products Product[]

  @@map("categories")
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("brands")
}

model Unit {
  id           String   @id @default(uuid())
  name         String   @unique
  abbreviation String   @unique
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("units")
}

model Product {
  id            String   @id @default(uuid())
  name          String
  description   String?
  sku           String?  @unique
  barcode       String?  @unique
  igvType       IgvType  @default(GRAVADO) @map("igv_type")
  purchasePrice Decimal  @default(0) @map("purchase_price") @db.Decimal(12, 4)
  salePrice     Decimal  @default(0) @map("sale_price") @db.Decimal(12, 4)
  minStock      Int      @default(0) @map("min_stock")
  maxStock      Int      @default(0) @map("max_stock")
  image         String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  categoryId String?   @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id])

  brandId String? @map("brand_id")
  brand   Brand?  @relation(fields: [brandId], references: [id])

  unitId String? @map("unit_id")
  unit   Unit?   @relation(fields: [unitId], references: [id])

  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id])

  saleDetails     SaleDetail[]
  purchaseDetails PurchaseDetail[]
  inventories     Inventory[]
  kardexEntries   KardexEntry[]

  @@index([branchId])
  @@index([categoryId])
  @@index([brandId])
  @@map("products")
}

// ──────────────────────────────────────────
// Clientes y Proveedores
// ──────────────────────────────────────────

model Customer {
  id             String          @id @default(uuid())
  documentIdType DocumentIdType? @map("document_id_type")
  documentNumber String?         @map("document_number")
  firstName      String          @map("first_name")
  lastName       String          @map("last_name")
  email          String?
  phone          String?
  address        String?
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id])

  sales Sale[]

  @@index([branchId])
  @@index([documentNumber])
  @@map("customers")
}

model Supplier {
  id          String   @id @default(uuid())
  companyName String   @map("company_name")
  contactName String?  @map("contact_name")
  taxId       String?  @map("tax_id")
  email       String?
  phone       String?
  address     String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id])

  purchases Purchase[]

  @@index([branchId])
  @@map("suppliers")
}

// ──────────────────────────────────────────
// Ventas
// ──────────────────────────────────────────

enum SaleStatus {
  DRAFT
  CONFIRMED
  CANCELLED
  RETURNED
}

enum SaleDocumentType {
  FACTURA
  BOLETA
  NOTA_DE_VENTA
  NOTA_DE_CREDITO
  NOTA_DE_DEBITO
}

enum SunatStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum IgvType {
  GRAVADO
  EXONERADO
  INAFECTO
}

enum DocumentIdType {
  DNI
  RUC
  CE
  PASSPORT
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  CREDIT
  MIXED
}

model Sale {
  id            String           @id @default(uuid())
  documentType  SaleDocumentType @default(NOTA_DE_VENTA) @map("document_type")
  series        String?
  correlative   Int?
  status        SaleStatus       @default(DRAFT)
  sunatStatus   SunatStatus?     @map("sunat_status")
  xmlUrl        String?          @map("xml_url")
  cdrUrl        String?          @map("cdr_url")
  pdfUrl        String?          @map("pdf_url")
  subtotal      Decimal          @default(0) @db.Decimal(12, 4)
  igvAmount     Decimal          @default(0) @map("igv_amount") @db.Decimal(12, 4)
  iscAmount     Decimal          @default(0) @map("isc_amount") @db.Decimal(12, 4)
  discount      Decimal          @default(0) @db.Decimal(12, 4)
  total         Decimal          @default(0) @db.Decimal(12, 4)
  paymentMethod PaymentMethod    @default(CASH) @map("payment_method")
  notes         String?
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id])

  customerId String?   @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [id])

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  details      SaleDetail[]
  cashMovement CashMovement[]

  @@unique([series, correlative])
  @@index([branchId])
  @@index([createdAt])
  @@index([status])
  @@map("sales")
}

model SaleDetail {
  id        String  @id @default(uuid())
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 4)
  discount  Decimal @default(0) @db.Decimal(12, 4)
  subtotal  Decimal @db.Decimal(12, 4)

  saleId String @map("sale_id")
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])

  @@map("sale_details")
}

// ──────────────────────────────────────────
// Compras
// ──────────────────────────────────────────

enum PurchaseStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELLED
}

model Purchase {
  id             String         @id @default(uuid())
  documentNumber String?        @map("document_number")
  status         PurchaseStatus @default(DRAFT)
  subtotal       Decimal        @default(0) @db.Decimal(12, 4)
  taxAmount      Decimal        @default(0) @map("tax_amount") @db.Decimal(12, 4)
  total          Decimal        @default(0) @db.Decimal(12, 4)
  notes          String?
  receivedAt     DateTime?      @map("received_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id])

  supplierId String   @map("supplier_id")
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  details PurchaseDetail[]

  @@index([branchId])
  @@index([createdAt])
  @@map("purchases")
}

model PurchaseDetail {
  id        String  @id @default(uuid())
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 4)
  subtotal  Decimal @db.Decimal(12, 4)

  purchaseId String   @map("purchase_id")
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])

  @@map("purchase_details")
}

// ──────────────────────────────────────────
// Inventario y Kardex
// ──────────────────────────────────────────

model Inventory {
  id       String @id @default(uuid())
  quantity Int    @default(0)

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])

  warehouseId String    @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id])

  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([productId, warehouseId])
  @@index([branchId])
  @@map("inventories")
}

enum KardexMovementType {
  PURCHASE_IN
  SALE_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  TRANSFER_IN
  TRANSFER_OUT
  RETURN_IN
  RETURN_OUT
}

model KardexEntry {
  id            String             @id @default(uuid())
  movementType  KardexMovementType @map("movement_type")
  quantity      Int
  previousStock Int                @map("previous_stock")
  newStock      Int                @map("new_stock")
  unitCost      Decimal            @default(0) @map("unit_cost") @db.Decimal(12, 4)
  totalCost     Decimal            @default(0) @map("total_cost") @db.Decimal(12, 4)
  reference     String?
  notes         String?
  createdAt     DateTime           @default(now()) @map("created_at")

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])

  warehouseId String    @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id])

  @@index([productId])
  @@index([warehouseId])
  @@index([createdAt])
  @@map("kardex_entries")
}

// ──────────────────────────────────────────
// Caja
// ──────────────────────────────────────────

enum CashRegisterStatus {
  OPEN
  CLOSED
}

model CashRegister {
  id             String             @id @default(uuid())
  name           String
  status         CashRegisterStatus @default(CLOSED)
  openingAmount  Decimal            @default(0) @map("opening_amount") @db.Decimal(12, 4)
  closingAmount  Decimal?           @map("closing_amount") @db.Decimal(12, 4)
  expectedAmount Decimal?           @map("expected_amount") @db.Decimal(12, 4)
  difference     Decimal?           @db.Decimal(12, 4)
  openedAt       DateTime?          @map("opened_at")
  closedAt       DateTime?          @map("closed_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id])

  movements CashMovement[]

  @@index([branchId])
  @@index([status])
  @@map("cash_registers")
}

enum CashMovementType {
  SALE
  EXPENSE
  DEPOSIT
  WITHDRAWAL
}

model CashMovement {
  id          String           @id @default(uuid())
  type        CashMovementType
  amount      Decimal          @db.Decimal(12, 4)
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")

  cashRegisterId String       @map("cash_register_id")
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id])

  saleId String? @map("sale_id")
  sale   Sale?   @relation(fields: [saleId], references: [id])

  @@index([cashRegisterId])
  @@index([createdAt])
  @@index([saleId])
  @@map("cash_movements")
}
